{
  "version": 1,
  "disable_existing_loggers": false,
  "formatters": {
    "verbose": {
      "format": "%(asctime)s - %(name)s - %(levelname)s - %(message)s",
      "datefmt": "%Y-%m-%d %H:%M:%S"
    },
    "simple": {
      "format": "%(levelname)s: %(message)s"
    }
  },
  "handlers": {
    "file": {
      "class": "logging.FileHandler",
      "filename": "logs",
      "formatter": "verbose",
      "level": "DEBUG",
      "encoding": "utf-8"
    },
    "console": {
      "class": "logging.StreamHandler",
      "formatter": "simple",
      "level": "INFO"
    }
  },
  "root": {
    "handlers": ["file", "console"],
    "level": "DEBUG"
  }
}
