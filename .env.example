# =============================================================================
# ОБЩИЕ НАСТРОЙКИ
# =============================================================================

# UID для запуска Airflow-контейнеров (должен совпадать с UID хоста для прав доступа к volumes)
AIRFLOW_UID=50000


# =============================================================================
# CLICKHOUSE (DWH)
# =============================================================================

# Имя хоста ClickHouse внутри Docker-сети (используется в DAG/ETL, не самим ClickHouse)
CLICKHOUSE_HOST=clickhouse

# HTTP-порт ClickHouse (используется в DAG/ETL, не самим ClickHouse)
CLICKHOUSE_PORT=8123

# Имя базы данных по умолчанию
CLICKHOUSE_DB=etl

# Имя пользователя ClickHouse
CLICKHOUSE_USER=etl_user

# Пароль пользователя ClickHouse (смените на надёжный!)
CLICKHOUSE_PASSWORD=your_strong_password


# =============================================================================
# POSTGRES (метаданные Airflow + Superset)
# =============================================================================

# Имя хоста PostgreSQL внутри Docker-сети (используется в Airflow/Superset, не самим Postgres)
AIRFLOW_POSTGRES_HOST=postgres-airflow

# Порт PostgreSQL (используется в Airflow/Superset, не самим Postgres)
AIRFLOW_POSTGRES_PORT=5432

# Имя базы данных для Airflow
AIRFLOW_POSTGRES_DB=airflow

# Имя пользователя PostgreSQL
AIRFLOW_POSTGRES_USER=airflow

# Пароль пользователя PostgreSQL (смените на надёжный!)
AIRFLOW_POSTGRES_PASSWORD=another_strong_password


# =============================================================================
# MINIO (S3-совместимое хранилище)
# =============================================================================

# Root-пользователь MinIO
MINIO_ROOT_USER=minio_docker

# Root-пароль MinIO (минимум 8 символов!)
MINIO_ROOT_PASSWORD=strongpass

# Имя бакета для ETL-пайплайна (создаётся вручную или через init-скрипт)
MINIO_BUCKET=etl-pipeline

# Хост и порт API MinIO (используются в DAG/ETL, не самим MinIO)
MINIO_API_HOST=minio
MINIO_API_PORT=9000
MINIO_API_URL=${MINIO_API_HOST}:${MINIO_API_PORT}

# Хост и порт веб-консоли MinIO (используются в браузере, не самим MinIO)
MINIO_CONSOLE_HOST=minio
MINIO_CONSOLE_PORT=9001
MINIO_CONSOLE_URL=http://${MINIO_CONSOLE_HOST}:${MINIO_CONSOLE_PORT}


# =============================================================================
# AIRFLOW (все компоненты загружают .env через env_file)
# =============================================================================

# Исполнитель задач (LocalExecutor = локальные подпроцессы)
AIRFLOW__CORE__EXECUTOR=LocalExecutor

# Строка подключения к PostgreSQL для метаданных Airflow
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://${AIRFLOW_POSTGRES_USER}:${AIRFLOW_POSTGRES_PASSWORD}@${AIRFLOW_POSTGRES_HOST}:${AIRFLOW_POSTGRES_PORT}/${AIRFLOW_POSTGRES_DB}

# --- Настройки API-сервера (Airflow 3.0+) ---
# Политика SameSite для cookies (None = кросс-доменная работа фронтенда и API)
AIRFLOW__API__COOKIE_SAMESITE=None

# Включить ProxyFix для работы за reverse proxy
AIRFLOW__API__ENABLE_PROXY_FIX=True

# Секретный ключ для JWT-подписи (HS512).
# Сгенерируйте: openssl rand -hex 32
AIRFLOW__API_AUTH__JWT_SECRET=CHANGE_ME_64_HEX_CHARS_HERE__________________________

# Issuer для JWT-токенов
AIRFLOW__API_AUTH__JWT_ISSUER=airflow

# Базовый URL API-сервера
AIRFLOW__API__BASE_URL=http://airflow-api-server:8080

# URL execution API для Task SDK
AIRFLOW__CORE__EXECUTION_API_SERVER_URL=http://airflow-api-server:8080/execution/

# Auth manager (FAB = Flask-AppBuilder, требует apache-airflow-providers-fab)
AIRFLOW__CORE__AUTH_MANAGER=airflow.providers.fab.auth_manager.fab_auth_manager.FabAuthManager

# --- Настройки администратора (только при FAB auth manager) ---
_AIRFLOW_WWW_USER_CREATE=true
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=admin
_AIRFLOW_WWW_USER_EMAIL=admin@example.com
_AIRFLOW_WWW_USER_ROLE=Admin


# =============================================================================
# REDIS (кэш + rate limiting)
# =============================================================================

# Пароль Redis (минимум 8 символов для Redis 8.8+)
REDIS_PASSWORD=strongpass

# Порт Redis
REDIS_PORT=6379

# URL подключения к Redis (используется Superset и Airflow)
REDIS_URL=redis://:${REDIS_PASSWORD}@redis_rate_limiter:${REDIS_PORT}

# Хранилище для Flask-Limiter 
RATELIMIT_STORAGE_URI=${REDIS_URL}/0


# =============================================================================
# SUPERSET (BI-платформа)
# =============================================================================

# Строка подключения к PostgreSQL (отдельная база/схема от Airflow)
SUPERSET__SQLALCHEMY_DATABASE_URI=postgresql+psycopg2://${AIRFLOW_POSTGRES_USER}:${AIRFLOW_POSTGRES_PASSWORD}@${AIRFLOW_POSTGRES_HOST}:${AIRFLOW_POSTGRES_PORT}/superset

# Секретный ключ Superset (минимум 16 символов)
# Сгенерируйте: openssl rand -base64 42
SUPERSET_SECRET_KEY=supersecretkey

# Данные администратора Superset
SUPERSET_ADMIN_USER=admin
SUPERSET_ADMIN_PASSWORD=admin
SUPERSET_ADMIN_EMAIL=admin@example.com

# =============================================================================
# ETL ПАРАМЕТРЫ
# =============================================================================

# API-токен PandaScore (получить: https://pandascore.co/)
PANDASCORE_TOKEN=your_pandascore_token_here

# =============================================================================
# ВРЕМЕННАЯ ЗОНА
# =============================================================================

TZ=Europe/Samara
